# ===== Lab04 Companion Computer Configuration =====
# This single .env file is used by all projects (1-8)
# Not all variables are used in every project - see comments

# ===== CORE MQTT SETTINGS (Projects 2-8) =====
# These are essential for any project using MQTT.
# The broker address and credentials are provided at the session.

MQTT_BROKER=your-mqtt-broker.example.com
MQTT_PORT=1883                    # Use 8883 for TLS
MQTT_USE_TLS=false                # Set to true for secure connection

# Optional TLS variant (see the Project 2 notes): use the broker's TLS port,
# enable MQTT_USE_TLS, and point to the CA certificate.
# MQTT_PORT=8883
# MQTT_USE_TLS=true
# MQTT_CA_CERT_PATH=ca.crt        # Relative path is OK if you run from this folder

# ===== BASIC MQTT CREDENTIALS (Projects 2-3) =====
# Projects 2-3 use these simple credentials
# Note: Projects 4-8 use role-specific credentials below instead

MQTT_USERNAME=your_username       # Provided at the session
MQTT_PASSWORD=your_password       # Provided at the session

# ===== NAMESPACE (Projects 4-8) =====
# TEAM_NS: your team id, as assigned at the session (team1..team4). It selects
# your broker login below.
# FLEET_NS: the topic prefix for one running fleet = team + surname. Replace
# "yoursurname" with your own surname (lowercase latin letters). Running alone,
# use your own surname; running boats together with others, everyone joining
# the same fleet sets the SAME FLEET_NS.
# Order matters: keep these two lines ABOVE everything that uses them (the .env
# resolves ${...} reading top-to-bottom).

TEAM_NS=team1
FLEET_NS=${TEAM_NS}/yoursurname

# ===== MQTT TOPICS (Projects 4-8) =====
# Topics for multi-vessel coordination (each prefixed with FLEET_NS)

SCOUT_POSITION_TOPIC=${FLEET_NS}/scout/position
VESSEL1_POSITION_TOPIC=${FLEET_NS}/vessel1/position
VESSEL2_POSITION_TOPIC=${FLEET_NS}/vessel2/position
VESSEL3_POSITION_TOPIC=${FLEET_NS}/vessel3/position

# ===== ROLE-BASED MQTT CREDENTIALS (Projects 4-8) =====
# Every boat in a team logs in with that team's login. The broker has one login
# per team (password = username), and ${TEAM_NS} selects it, so a team shares
# one login while the topics (above) keep the running fleets separated.

# Scout configuration
SCOUT_MQTT_USERNAME=${TEAM_NS}
SCOUT_MQTT_PASSWORD=${TEAM_NS}

# Vessel 1 configuration
VESSEL1_MQTT_USERNAME=${TEAM_NS}
VESSEL1_MQTT_PASSWORD=${TEAM_NS}
VESSEL1_COMMANDS=${FLEET_NS}/vessel1/commands

# Vessel 2 configuration
VESSEL2_MQTT_USERNAME=${TEAM_NS}
VESSEL2_MQTT_PASSWORD=${TEAM_NS}
VESSEL2_COMMANDS=${FLEET_NS}/vessel2/commands

# Vessel 3 configuration
VESSEL3_MQTT_USERNAME=${TEAM_NS}
VESSEL3_MQTT_PASSWORD=${TEAM_NS}
VESSEL3_COMMANDS=${FLEET_NS}/vessel3/commands

# ===== SITL CONNECTION STRINGS (Projects 4-8) =====
# UDP connections for SITL simulation. The standard port 14550 belongs to your
# graphical ground station (Mission Planner / QGroundControl), so each boat's
# Python reads its own private port instead: the boat's instance default + 1
# (instance N gives 14551 + 10N). Launch every boat with two --out flags: one
# copy for the ground station on 14550, one copy for the boat's Python on the
# port below. Projects 1-3 use hardcoded connection strings.

SCOUT_CONNECTION_STRING=udp:127.0.0.1:14551
VESSEL1_CONNECTION_STRING=udp:127.0.0.1:14561
VESSEL2_CONNECTION_STRING=udp:127.0.0.1:14571
VESSEL3_CONNECTION_STRING=udp:127.0.0.1:14581

# ===== HARDWARE CONNECTION STRINGS (Future use) =====
# Serial connections for real hardware (covered in Section 4)
# Currently commented out - uncomment when using real hardware

# SCOUT_REAL_CONNECTION_STRING=/dev/pixhawk_scout
# VESSEL1_REAL_CONNECTION_STRING=/dev/pixhawk1
# VESSEL2_REAL_CONNECTION_STRING=/dev/pixhawk2
# VESSEL3_REAL_CONNECTION_STRING=/dev/pixhawk3

# ===== OPERATIONAL PARAMETERS (Projects 7+) =====
# Behavioral parameters for autonomous operations

SAFE_FOLLOW_DISTANCE=15          # Keep-out ring around the scout, meters (keep below FORMATION_DISTANCE)
TELEMETRY_INTERVAL=1             # Publish rate in seconds (wired in Project 8; Projects 1-7 publish every 5 s)
FORMATION_DISTANCE=30            # Project 8: how far from the scout each vessel stations, meters
